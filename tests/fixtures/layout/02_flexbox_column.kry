// Flexbox layout - column direction
// Tests: Vertical flexbox, align_items, justify_content
App {
    window_width: 800
    window_height: 600
    
    Container {
        display: flex
        flex_direction: column
        justify_content: center
        align_items: center
        width: 300
        height: 400
        background_color: "#f1f5f9"
        border: "2px solid #e2e8f0"
        
        Text {
            text: "Header"
            font_size: 24
            font_weight: "bold"
            margin_bottom: 20
            text_color: "#1e293b"
        }
        
        Container {
            width: 200
            height: 100
            background_color: "#ddd6fe"
            margin_bottom: 20
            display: flex
            justify_content: center
            align_items: center
            
            Text {
                text: "Content"
                font_size: 16
                text_color: "#7c3aed"
            }
        }
        
        Button {
            text: "Action"
            width: 100
            height: 35
            background_color: "#8b5cf6"
            text_color: "#ffffff"
            border_radius: 6
        }
    }
}
# =========================================================================
# Kryon Monorepo .gitignore - Unified for Compiler and Renderer
# =========================================================================

# Rust & Cargo
# -------------------------------------------------------------------------
/target/
**/**/target/
*.pdb
*.rs.bk

# Build artifacts
/examples/**/target/
/crates/**/target/
*.krb
*.o
*.so
*.dylib
*.dll
*.exe
kryc
kryc.exe

# Generated documentation
/doc/
/target/doc/

# IDE & Editor Configuration
# -------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Operating System Files
# -------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs & Data
# -------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Code coverage reports
/coverage/
*.lcov
lcov.info

# Secrets & Environment Variables
# -------------------------------------------------------------------------
.env
.env.*
!/.env.example

# Build directories
# -------------------------------------------------------------------------
/build/
/dist/
# Kryon-specific Files
# -------------------------------------------------------------------------
# Generated KRB files from examples
/test-files/*.krb
/examples/**/*.krb
hello_world_bundled

# Kryon build artifacts
**/.build/
*.kir.json
*.scripts/

# Kryon renderer specific logs
ratatui.log
debug_log.txt
full_debug.txt

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Test snapshots
crates/kryon-ratatui/src/snapshots/

# Jest testing artifacts (from HTML validation tests)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
coverage/
.nyc_output/
jest-results.xml
test-results/

# Font files (can be large)
*.ttf
*.otf
*.woff
*.woff2

# HTML backend output
html-test/
output/
web-examples/
*.html
*.css
*.js
kryon-*.css
kryon-*.js

# Modular renderer system artifacts
/target/release/kryon-renderer-*
/target/debug/kryon-renderer-*
renderer-output/
example-output/

# Profiling & Performance
# -------------------------------------------------------------------------
*.prof
perf.data*
flamegraph.svg
flamegraph-*.svg
perf-*.svg
*.perf

# GPU debug files
*.pix
*.nsight-cuprof
*.nvvp

# Memory profiling
massif.out.*
cachegrind.out.*
callgrind.out.*
vgcore.*
*.core

# Crash dumps
crash-*.log
*.dmp
core.*

# WebAssembly & Web
# -------------------------------------------------------------------------
pkg/
*.wasm
www/pkg/
www/node_modules/
www/dist/
.emscripten_cache/

# Caches & Temporary Files
# -------------------------------------------------------------------------
.cache
.parcel-cache
.asset-cache/
.shader-cache/
.rust-analyzer/
tmp/
temp/
.tmp/
.local/
local.toml

# Modular build temporary files
*.krb.tmp
build-cache/
renderer-cache/
.build-lock
example-*.krb
*-temp.html
*-temp.css

# Generated & Build Files
# -------------------------------------------------------------------------
generated/
gen/
src/bindings.rs
releases/
book/
mdbook/
criterion/

# Platform-specific
# -------------------------------------------------------------------------
*.xcodeproj/
*.xcworkspace/
DerivedData/
*.apk
*.aab
local.properties
*.ipa
*.dSYM.zip
*.dSYM

# Editor backup files
*.bak
*.orig
*.un~
Session.vim
.netrwhist
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
temp/

                        font_size: 14
                        font_weight: "bold"
                        text_color: "#374151"
                    }
                    
                    Text {
                        text: "Memory usage test"
                        font_size: 12
                        text_color: "#6b7280"
                    }
                }
                
                Container {
                    width: 200
                    height: 80
                    background_color: "#ffffff"
                    border: "1px solid #e5e7eb"
                    border_radius: 8
                    padding: 10
                    display: flex
                    flex_direction: column
                    justify_content: center
                    
                    Text {
                        text: "Nested Layout 3"
                        font_size: 14
                        font_weight: "bold"
                        text_color: "#374151"
                    }
                    
                    Text {
                        text: "Render time test"
                        font_size: 12
                        text_color: "#6b7280"
                    }
                }
            }
        }
    }
}
#!/usr/bin/env rc
# Build AppImage with embedded Marrow

kry_file = $1
app_name = `{basename $kry_file .kry}
appdir = $app_name^.AppDir
output = $app_name^-x86_64.AppImage

echo '[kryon] Creating AppImage: '^$output

# Create AppDir structure
rm -rf $appdir
mkdir -p $appdir/usr/bin
mkdir -p $appdir/usr/lib
mkdir -p $appdir/usr/share/applications

# Copy binaries
cp ../bin/marrow $appdir/usr/bin/
cp bin/kryon-wm $appdir/usr/bin/
cp bin/kryon-view $appdir/usr/bin/

# Copy application
cp $kry_file $appdir/usr/bin/app.kry

# Create AppRun wrapper
cat > $appdir/AppRun <<'EOF'
#!/bin/rc
# AppRun wrapper for AppImage

appdir = `{dirname $0}

# Start Marrow
$appdir/usr/bin/marrow &
marrow_pid = $apid
sleep 1

# Start WM
$appdir/usr/bin/kryon-wm --run $appdir/usr/bin/app.kry &
wm_pid = $apid
sleep 1

# Start viewer
$appdir/usr/bin/kryon-view

# Cleanup
kill $marrow_pid $wm_pid >/dev/null 2>&1
EOF

chmod +x $appdir/AppRun

# Create desktop file
echo '[Desktop Entry]' > $appdir/usr/share/applications/$app_name.desktop
echo 'Name='$app_name >> $appdir/usr/share/applications/$app_name.desktop
echo 'Exec=AppRun' >> $appdir/usr/share/applications/$app_name.desktop
echo 'Icon='$app_name >> $appdir/usr/share/applications/$app_name.desktop
echo 'Type=Application' >> $appdir/usr/share/applications/$app_name.desktop
echo 'Categories=Utility;' >> $appdir/usr/share/applications/$app_name.desktop

# Build AppImage (requires appimagetool)
if (! test -x appimagetool-x86_64.AppImage) {
    echo '[kryon] Downloading appimagetool...'
    wget -q https://github.com/AppImage/AppImageKit/releases/download/13/appimagetool-x86_64.AppImage
    chmod +x appimagetool-x86_64.AppImage
}

./appimagetool-x86_64.AppImage $appdir $output

echo '[kryon] Created: '^$output
